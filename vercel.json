{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/public/host.html" },
    { "src": "^/host$", "dest": "/public/host.html" },
    { "src": "^/player$", "dest": "/public/player.html" },
    { "src": "^/(.*)$", "dest": "/public/$1" }
  ]
}
